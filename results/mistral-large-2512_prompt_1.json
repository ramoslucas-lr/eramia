{
  "Entities": {
    "EMPLOYEE": {
      "attributes": ["Ssn", "Fname", "Minit", "Lname", "Bdate", "Address", "Sex", "Salary"],
      "pk": ["Ssn"],
      "fk": ["Supervisor_Ssn"]
    },
    "DEPARTMENT": {
      "attributes": ["Number", "Name", "Locations", "Number_of_employees"],
      "pk": ["Number"],
      "fk": ["Manager_Ssn", "Controlling_Department_Number"]
    },
    "PROJECT": {
      "attributes": ["Number", "Name", "Location", "Department_Number"],
      "pk": ["Number"],
      "fk": ["Department_Number"]
    },
    "DEPENDENT": {
      "attributes": ["Employee_Ssn", "Name", "Sex", "Birth_date", "Relationship"],
      "pk": ["Employee_Ssn", "Name"],
      "fk": ["Employee_Ssn"]
    },
    "WORKS_FOR": {
      "attributes": ["Employee_Ssn", "Department_Number"],
      "pk": ["Employee_Ssn"],
      "fk": ["Employee_Ssn", "Department_Number"]
    },
    "MANAGES": {
      "attributes": ["Employee_Ssn", "Department_Number", "Start_date"],
      "pk": ["Employee_Ssn"],
      "fk": ["Employee_Ssn", "Department_Number"]
    },
    "WORKS_ON": {
      "attributes": ["Employee_Ssn", "Project_Number", "Hours"],
      "pk": ["Employee_Ssn", "Project_Number"],
      "fk": ["Employee_Ssn", "Project_Number"]
    },
    "SUPERVISION": {
      "attributes": ["Supervisor_Ssn", "Supervisee_Ssn"],
      "pk": ["Supervisor_Ssn", "Supervisee_Ssn"],
      "fk": ["Supervisor_Ssn", "Supervisee_Ssn"]
    },
    "CONTROLS": {
      "attributes": ["Department_Number", "Project_Number"],
      "pk": ["Project_Number"],
      "fk": ["Department_Number", "Project_Number"]
    }
  }
}